# Copy to .env and adjust. All values have sensible defaults (see backend/config.py).
# Keep comments on their OWN lines (an inline "# ..." after a value is now stripped,
# but own-line comments are clearest).

# ---- Embedding (reused Qwen3-Embedding-4B, tuned for a 4 GB RTX 2050) ----
# EMBEDDER: st = real model (fail loudly); hashing = dev-only, no GPU (768-dim)
EMBEDDER=st
EMBED_MODEL=unsloth/Qwen3-Embedding-4B
EMBED_DEVICE=cuda
# 4-bit NF4; set 0 for full precision (needs more VRAM than a 2050 has)
EMBED_LOAD_IN_4BIT=1
# Encode batch size; drop to 4 or 2 if you hit CUDA out-of-memory
EMBED_BATCH_SIZE=8

# ---- Dialect / data source ----
SQL_DIALECT=sqlite
# A ready-to-use copy of the database is bundled at data/sales.db and used by
# default — no configuration needed. Point at a different SQLite file to override:
# DB_PATH=data/sales.db

# ---- App ----
# Set 0 to run the API without loading the model (plumbing only):
# LOAD_EMBEDDER=1

# ---- LLM (Phase 7): the single remote call per turn (OpenAI-compatible) ----
LLM_BASE_URL=http://header-drainable-turbulent.ngrok-free.dev/v1
# Leave LLM_MODEL blank to auto-discover the served id via GET {base}/models.
# Pin it once you know the id (faster + avoids the /models round-trip).
# LLM_MODEL=
# LLM_API_KEY=            # only if the endpoint requires one
# LLM_TIMEOUT=120
# LLM_TEMPERATURE=0
# LLM_MAX_TOKENS=1200
# LLM_NGROK_SKIP_WARNING=1   # send ngrok-skip-browser-warning header
# LLM_TRY_JSON_OBJECT=1      # try response_format=json_object (auto-fallback if rejected)
# LLM_SELF_REPAIR=1          # one repair round-trip on a validation/exec failure

# ---- SQL validation + execution (Phase 8) ----
# MAX_RESULT_ROWS=500        # hard fetch cap + LIMIT ceiling
# RAW_SELECT_LIMIT=100       # LIMIT ceiling for raw (non-aggregate) row SELECTs
# AUTO_LIMIT=200             # LIMIT injected when a raw SELECT omits one
# EXPLAIN_MAX_SCAN_ROWS=500000  # scan above this -> warning only
# QUERY_TIMEOUT_SEC=10
