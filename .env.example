# Copy to .env and adjust. All values have sensible defaults (see backend/config.py).
# Keep comments on their OWN lines (an inline "# ..." after a value is stripped,
# but own-line comments are clearest).

# ---- Embedding (Qwen3-Embedding-4B, tuned for a 4 GB RTX 2050) ----
# EMBEDDER: st = real model (fail loudly if it can't load);
#           hashing = dev-only fallback, no GPU (768-dim, non-semantic)
EMBEDDER=st
EMBED_MODEL=unsloth/Qwen3-Embedding-4B
EMBED_DEVICE=cuda
# 4-bit NF4; set 0 for full precision (needs more VRAM than a 2050 has)
EMBED_LOAD_IN_4BIT=1
# Encode batch size; drop to 4 or 2 if you hit CUDA out-of-memory
EMBED_BATCH_SIZE=8

# ---- Dialect / data source ----
SQL_DIALECT=sqlite
# A ready-to-use copy of the database is bundled at data/sales.db and used by
# default -- no configuration needed. Point at a different SQLite file to override:
# DB_PATH=data/sales.db
# Data window the synthetic DB actually covers (relative-date questions clamp to this):
# DATA_MIN_DATE=2024-01-01
# DATA_MAX_DATE=2025-06-24

# ---- App ----
# Set 0 to run the API without loading the model (plumbing only; KB editing still works):
# LOAD_EMBEDDER=1

# ---- LLM (the remote OpenAI-compatible endpoint; llama-server / Ollama) ----
# NOTE: web research (below) needs native tool-calling. Start llama.cpp with --jinja so the
# Qwen tool templates load, or use an Ollama model whose template declares tools. Without it
# the model emits no tool_calls and research cleanly skips (offline report still ships).
LLM_BASE_URL=https://header-drainable-turbulent.ngrok-free.dev/v1
# Pin LLM_MODEL to the served id. This endpoint's /v1/models answers in Ollama shape
# ({"models":[...]}), so blank auto-discovery cannot read the id — pin it here.
LLM_MODEL=qwen35-9b
# LLM_MODEL_FALLBACK=qwen35-9b # used when discovery fails
# LLM_API_KEY=                 # only if the endpoint requires one
# LLM_TIMEOUT=120
# Per-call generation params: SQL/planner (deterministic, short) vs analytic writer (warmer, longer)
# LLM_TEMPERATURE_SQL=0
# LLM_MAX_TOKENS_SQL=1200
# LLM_TEMPERATURE_WRITER=0.4
# LLM_MAX_TOKENS_WRITER=0       # 0 = do not send max_tokens for long analytic reports
# LLM_NGROK_SKIP_WARNING=1     # send ngrok-skip-browser-warning header (harmless for llama.cpp)
# LLM_TRY_JSON_OBJECT=1        # try response_format=json_object (auto-fallback if rejected)
# LLM_SELF_REPAIR=1            # one repair round-trip on a validation/exec failure
# LLM_STREAM=1                 # stream tokens over SSE (falls back to blocking automatically)

# ---- Knowledge base: live updates (Phase 10) ----
# KB_AUTO_RENDER=1             # re-render skill.md + embedding_docs.jsonl after every save/delete
# KB_VALIDATE_ON_SAVE=strict   # strict | warn | off  (save-time entry validation)
# VALUE_SAMPLE_LIMIT=200       # distinct values pulled per column by /api/knowledge/sync-values

# ---- Analytic mode (Phase 11-14) ----
# Master gate for the analytic pipeline. 1 = analytic turns run the review controller
# (planner -> tasks -> profiler -> evidence/charts -> persist); 0 = detect + log the mode
# but always run the normal SQL pipeline (normal chat unchanged).
# ANALYTIC_ENABLED=1
# Review budgets (plan §14, §21.2).
# ANALYTIC_MAX_TASKS=6            # max validated SQL tasks per review
# ANALYTIC_MAX_REPAIRS_PER_TASK=1 # LLM self-repair rounds per task on a runtime error
# ANALYTIC_TOTAL_BUDGET_SEC=120  # wall-clock per review; remaining tasks skipped w/ caveat
# ANALYTIC_EVIDENCE_MAX_ROWS=20  # rows stored per evidence item (full result never persisted)
# ANALYTIC_CHART_MAX_POINTS=50   # hard cap on chart data points
# Analytic retrieval buckets (playbooks, caveats, dimensions) — shared index, bucketed.
# RETRIEVAL_TOPK_PLAYBOOK=2
# RETRIEVAL_TOPK_CAVEAT=3
# RETRIEVAL_TOPK_DIMENSION=4

# ---- Web research via SearxNG (Phase 17, native tool-calling) ----
# 1 = after the SQL tasks profile, one LLM call emits search_internet tool calls; the backend
# runs each against SearxNG (<=5, cache-first) and cites web sources in "Bối cảnh thị trường".
# Any failure (disabled / SearxNG down / no tool calls) skips research; the offline report
# always ships. search_internet appends /search to SEARXNG_URL (SearxNG is at the ngrok root).
SEARCH_ENABLED=1
SEARXNG_URL=https://header-drainable-turbulent.ngrok-free.dev
# Legacy alias also accepted: DATAMIND_SEARXNG_URL=
# SEARCH_TIMEOUT_SEC=10
# SEARCH_LANGUAGE=vi
# SEARCH_MAX_RESULTS=5           # top-N SearxNG results kept per query
# SEARCH_MAX_SNIPPET_CHARS=500   # snippet truncation length
# SEARCH_MAX_CALLS_PER_REVIEW=5  # total tool calls executed per review
# SEARCH_MAX_SOURCES_PER_QUERY=3 # web sources kept per query
# SEARCH_MAX_QUERY_CHARS=200
# SEARCH_CACHE_TTL_HOURS=24      # repeated normalized query within this window skips the HTTP call

# ---- SQL validation + execution ----
# MAX_RESULT_ROWS=500          # hard fetch cap + LIMIT ceiling
# RAW_SELECT_LIMIT=100         # LIMIT ceiling for raw (non-aggregate) row SELECTs
# AUTO_LIMIT=200               # LIMIT injected when a raw SELECT omits one
# EXPLAIN_MAX_SCAN_ROWS=500000 # scan above this -> warning only
# QUERY_TIMEOUT_SEC=10

# ---- Logging + health (Phase 9) ----
# LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=console           # console (human-readable) | json
# LOG_FILE=logs/app.jsonl      # JSON-lines file (rotating); blank = console only
# HEALTH_CACHE_SEC=30          # GET /api/health cache TTL
